# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
build/
dist/

# Secrets / config (never commit keys or tokens)
.env
.env.*
!.env.example
*.key
secrets.*
credentials.json

# Generated datasets & model artifacts (published to the HF Hub, not git)
data/generated/

# Downloaded full vocab lists (fetched on demand; see data/vocab/SOURCES.md for licenses)
data/vocab/**/*.full.csv

# Curated (second-pass) output — regenerated from generated data by islm.datagen.curate
data/curated/
# Compacted teacher data + combined training corpora (regenerated: islm.datagen.compact + concat)
data/compact/
data/v7_corpus/
*.parquet
*.arrow
checkpoints/
outputs/
*.gguf
*.safetensors
*.bin

# Eval run outputs (regenerated by the harness)
evals/results/

# Experiment tracking / logs
wandb/
runs/
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
# The dataset itself is large + regenerable (HF Hub, not git), like other data/.
data/generated/synth_*/
data/curated/synth_*/
# dataset_v1: ship the gzipped splits + stats so Colab can use them without regenerating.
# Raw .jsonl stays ignored (train.jsonl is ~193 MB, over GitHub's 100 MB file limit).
data/dataset_v1/*
!data/dataset_v1/*.jsonl.gz
!data/dataset_v1/stats.json
