# Copy to .env (which is git-ignored). NEVER commit real keys.
# The client is OpenAI-compatible, so set the base_url to any provider or local server.

OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

# Teacher generates data; judge scores it. Use different model families to reduce
# self-preference bias (see PRD 11).
TEACHER_MODEL=gpt-5
JUDGE_MODEL=claude-sonnet-5

# LangSmith: push the golden set + eval runs for dataset/experiment tracking (augment mode).
# Optional — evals run fully offline without it. See src/islm/eval/langsmith_sync.py.
LANGSMITH_API_KEY=lsv2_pt_replace-me
LANGSMITH_PROJECT=islm-evals
